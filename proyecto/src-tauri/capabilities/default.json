{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "fs:default",
    "http:default",
    "fs:allow-appdata-read",
    "fs:allow-appdata-write",
    "fs:allow-appdata-meta",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/whatsapp-bot",
          "sidecar": true
        }
      ]
    },
    "shell:allow-kill"
  ]
}
